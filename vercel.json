{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "outputDirectory": "build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://51.20.34.254:5000/api/$1" },
    { "source": "/uploads/(.*)", "destination": "http://51.20.34.254:5000/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
